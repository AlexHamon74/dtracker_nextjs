generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Expenses { 
  id        Int     @id @default(autoincrement()) 
  name     String
  amount   Float
  categoryId Int
  category   Categories @relation(fields: [categoryId], references: [id])
  createdAt Boolean @default(false) 
} 

model Categories { 
  id        Int     @id @default(autoincrement()) 
  name     String

  expenses Expenses[]
} 